{
  "info": {
    "name": "Learnyx API",
    "description": "REST API для платформи онлайн-репетиторства Learnyx. Система управляє заняттями, учнями, викладачами, пакетами уроків та системою бонусів (Learning Cashback).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Реєстрація, авторизація та управління токенами",
      "item": [
        {
          "name": "Подача заявки на реєстрацію",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"SecurePass123\",\n  \"first_name\": \"Іван\",\n  \"last_name\": \"Петренко\",\n  \"phone\": \"+380991234567\",\n  \"role\": \"student\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Учень або викладач подає заявку. Менеджер активує акаунт вручну.\n\nExpected: 201 Created\nErrors: 400 (Невалідний формат email), 409 (Email вже зареєстрований)"
          },
          "response": [
            {
              "name": "201 Created — Заявку подано",
              "status": "Created",
              "code": 201,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"id\": 1,\n  \"email\": \"student@example.com\",\n  \"is_approved\": false,\n  \"message\": \"Заявку прийнято. Очікуйте підтвердження менеджера.\"\n}"
            },
            {
              "name": "409 Conflict — Email вже існує",
              "status": "Conflict",
              "code": 409,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"timestamp\": \"2026-04-06T10:00:00Z\",\n  \"errorCode\": \"EMAIL_ALREADY_EXISTS\",\n  \"message\": \"Користувач з таким email вже існує\",\n  \"path\": \"/api/v1/auth/register/\"\n}"
            }
          ]
        },
        {
          "name": "Авторизація користувача (Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', response.access);",
                  "    pm.test('Token saved', () => pm.expect(response.access).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"SecurePass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Авторизація через email/password. Повертає JWT access + refresh токени.\n\nExpected: 200 OK\nErrors: 400 (Невалідний формат), 401 (Невірний email або пароль)"
          },
          "response": [
            {
              "name": "200 OK — Успішна авторизація",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"student@example.com\",\n    \"role\": \"student\",\n    \"full_name\": \"Іван Петренко\"\n  }\n}"
            },
            {
              "name": "401 Unauthorized — Невірний пароль",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"timestamp\": \"2026-04-06T10:00:00Z\",\n  \"errorCode\": \"INVALID_CREDENTIALS\",\n  \"message\": \"Невірний email або пароль\",\n  \"path\": \"/api/v1/auth/login/\"\n}"
            }
          ]
        },
        {
          "name": "Оновлення access токена",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["auth", "token", "refresh", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Оновлення access токена через refresh токен.\n\nExpected: 200 OK\nErrors: 401 (Refresh токен недійсний або прострочений)"
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "Профілі користувачів (Student, Teacher, Manager)",
      "item": [
        {
          "name": "Отримати профіль поточного користувача",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/me/",
              "host": ["{{base_url}}"],
              "path": ["users", "me", ""]
            },
            "description": "Повертає профіль авторизованого користувача.\n\nExpected: 200 OK\nErrors: 401 (Токен відсутній або недійсний)"
          },
          "response": [
            {
              "name": "200 OK — Профіль користувача",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"student@example.com\",\n  \"first_name\": \"Іван\",\n  \"last_name\": \"Петренко\",\n  \"role\": \"student\",\n  \"phone\": \"+380991234567\",\n  \"is_approved\": true,\n  \"level\": \"11 клас (НМТ)\"\n}"
            }
          ]
        },
        {
          "name": "Список учнів",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/students/",
              "host": ["{{base_url}}"],
              "path": ["users", "students", ""],
              "query": [
                {
                  "key": "level_id",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "is_approved",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Список учнів (для менеджера/викладача).\n\nExpected: 200 OK\nErrors: 401, 403 (Недостатньо прав)"
          }
        },
        {
          "name": "Список викладачів",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/teachers/",
              "host": ["{{base_url}}"],
              "path": ["users", "teachers", ""]
            },
            "description": "Список викладачів.\n\nExpected: 200 OK"
          }
        },
        {
          "name": "Підтвердження реєстрації (менеджер)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/approve/3/",
              "host": ["{{base_url}}"],
              "path": ["users", "approve", "3", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_approved\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Менеджер підтверджує реєстрацію користувача.\n\nExpected: 200 OK\nErrors: 403 (Не менеджер), 404 (Користувач не знайдений)"
          }
        }
      ]
    },
    {
      "name": "Slots",
      "description": "Управління часовими слотами викладача",
      "item": [
        {
          "name": "Отримати слоти викладача",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/slots/",
              "host": ["{{base_url}}"],
              "path": ["slots", ""],
              "query": [
                {
                  "key": "teacher_id",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "is_booked",
                  "value": "false",
                  "disabled": true
                },
                {
                  "key": "date",
                  "value": "2026-04-10",
                  "disabled": true
                }
              ]
