              }
            ],
            "url": {
              "raw": "{{base_url}}/slots/",
              "host": ["{{base_url}}"],
              "path": ["slots", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"start_time\": \"2026-04-10T10:00:00Z\",\n  \"end_time\": \"2026-04-10T11:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Викладач створює вільний слот у своєму розкладі.\n\nExpected: 201 Created\nErrors: 400 (Невалідні дані), 409 (Конфлікт часу)"
          },
          "response": [
            {
              "name": "201 Created — Слот створено",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 5,\n  \"teacher_id\": 1,\n  \"start_time\": \"2026-04-10T10:00:00Z\",\n  \"end_time\": \"2026-04-10T11:00:00Z\",\n  \"is_booked\": false\n}"
            },
            {
              "name": "409 Conflict — Конфлікт слотів",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"timestamp\": \"2026-04-06T10:00:00Z\",\n  \"errorCode\": \"SLOT_TIME_CONFLICT\",\n  \"message\": \"Часовий слот перетинається з вже існуючим\",\n  \"path\": \"/api/v1/slots/\"\n}"
            }
          ]
        },
        {
          "name": "Видалити слот",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/slots/5/",
              "host": ["{{base_url}}"],
              "path": ["slots", "5", ""]
            },
            "description": "Видалення незабронйованого слоту.\n\nExpected: 204 No Content\nErrors: 404 (Слот не знайдено), 409 (Слот вже заброньований)"
          }
        }
      ]
    },
    {
      "name": "Lessons",
      "description": "Бронювання та управління заняттями",
