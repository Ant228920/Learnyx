# ─────────────────────────────────────────────────────────────
#  Learnyx – server/.env.example
#  Скопіюй: cp server/.env.example server/.env
#  server/.env НЕ комітити в Git!
# ─────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────
SECRET_KEY=your_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_NAME=learnyx_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_HOST=db
DATABASE_PORT=5432

# ── pgAdmin ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@learnyx.local
PGADMIN_PASS=admin_password

# ── JWT ───────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email / SMTP ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
